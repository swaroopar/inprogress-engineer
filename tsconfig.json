{
    "extends": "@docusaurus/tsconfig",
    "compilerOptions": {
        "types": ["@docusaurus/plugin-ideal-image"],
        "ignoreDeprecations": "6.0",
        "paths": {
            "@site/*": ["./*"],
            "@site/src/components/*": ["./src/components/*"]
        }
    },
    "include": [
        "./src/**/*.*",
        "babel.config.js",
        "types.d.ts",
        "docusaurus.config.ts",
        "tailwind.config.ts",
        "sidebars.ts"
    ],
    "exclude": ["node_modules", "build", ".docusaurus", "eslint.config.mjs"]
}
